# ============================================================
# SuturaSec — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Clé secrète JWT (générez avec: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme_generate_a_strong_secret_key_here

# Algorithme de signature JWT
ALGORITHM=HS256

# Durée de vie du token en minutes (1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Base de données SQLite
DATABASE_URL=sqlite:///./suturasec.db

# Clé API Anthropic (Claude AI) — https://console.anthropic.com
# Laisser vide pour désactiver l'analyse IA (fallback statique)
ANTHROPIC_API_KEY=sk-ant-api03-...
